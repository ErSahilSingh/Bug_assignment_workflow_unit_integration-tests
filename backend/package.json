{
  "name": "mini-issue-tracker-backend",
  "version": "1.0.0",
  "description": "Backend for Mini Issue Tracker - a beginner MERN project",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=unit --runInBand --forceExit",
    "test:integration": "jest --testPathPattern=integration --runInBand --forceExit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  }
}
